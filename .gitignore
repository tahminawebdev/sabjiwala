.env
.env.local
.DS_Store
*.log
.claude/

# Vendor & composer-managed plugins (installed via composer install).
# Note the trailing /* — Git cannot re-include files under a directory that is
# itself ignored, so we ignore *contents* and use !.gitkeep to keep the dir.
/vendor/
/wp-content/plugins/*
!/wp-content/plugins/.gitkeep

# WP uploads (user content)
/wp-content/uploads/*
!/wp-content/uploads/.gitkeep

# Mu-plugins: composer-managed contents are ignored, but our hand-written
# security plugin is tracked.
/wp-content/mu-plugins/*
!/wp-content/mu-plugins/.gitkeep
!/wp-content/mu-plugins/shobjiwala-security.php

# WP core managed by docker image
/wp/
/wp-admin/
/wp-includes/
wp-*.php
!wp-config.php
!wp-config-docker.php
xmlrpc.php
license.txt
readme.html

# Default themes shipped by the WordPress docker image (not project assets)
/wp-content/themes/twentytwenty*/

# PHPCS caches
.phpcs-cache
.phpcs-security-cache
.phpcs-security-vendor-cache

# Local DB persistence
/db/data/

# IDE
.idea/
.vscode/
*.swp

# CCE (code-context-engine)
# CCE local cache (per-machine, not for version control)
.cce/
# Claude Code local settings written by cce init
.claude/settings.local.json
# .mcp.json contains absolute paths regenerated by `cce init`
.mcp.json
