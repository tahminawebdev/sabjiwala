# Hourly mysqldump. Output and errors flow to /var/log/backup.log,
# which the container tails to stdout so `docker compose logs db-backup`
# shows the audit trail.
SHELL=/bin/bash
PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

0 * * * * root /usr/local/bin/backup.sh >> /var/log/backup.log 2>&1
# trailing newline required by cron — keep it
