# Production environment template. Copy to .env on the prod host. The
# variables here are IN ADDITION to everything required by .env.example.

# ─── Public origin ─────────────────────────────────────────────────────────
WP_HOME=https://your-domain.example
WP_SITEURL=https://your-domain.example
WP_DEBUG=false

# ─── Database (same vars as .env.example, but use strong rotated secrets) ──
DB_NAME=shobjiwala
DB_USER=wp
DB_PASSWORD=                # REQUIRED — strong, unique, rotated
DB_ROOT_PASSWORD=           # REQUIRED — strong, unique, rotated
DB_HOST=db
TABLE_PREFIX=KAW_

# ─── WordPress secret keys (same vars as .env.example) ─────────────────────
# Generate eight fresh values with:
#   for i in {1..8}; do openssl rand -base64 48 | tr -d '\n'; echo; done
WORDPRESS_AUTH_KEY=
WORDPRESS_SECURE_AUTH_KEY=
WORDPRESS_LOGGED_IN_KEY=
WORDPRESS_NONCE_KEY=
WORDPRESS_AUTH_SALT=
WORDPRESS_SECURE_AUTH_SALT=
WORDPRESS_LOGGED_IN_SALT=
WORDPRESS_NONCE_SALT=

# ─── Redis (prod only) ─────────────────────────────────────────────────────
# openssl rand -base64 32
REDIS_PASSWORD=
# openssl rand -hex 16 — must be unique per environment so cache keys
# from staging never collide with prod.
WP_CACHE_KEY_SALT=
