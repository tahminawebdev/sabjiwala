# Copy to .env and fill in real values. .env is gitignored; never commit it.

# ─── Database ──────────────────────────────────────────────────────────────
# Generate strong passwords (no defaults are accepted by the stack):
#   openssl rand -base64 24
DB_NAME=shobjiwala
DB_USER=wp
DB_PASSWORD=                # REQUIRED — must be strong, unique per environment
DB_ROOT_PASSWORD=           # REQUIRED — must be strong, unique per environment
DB_HOST=db
TABLE_PREFIX=KAW_

# ─── WordPress ─────────────────────────────────────────────────────────────
WP_HOME=http://localhost:8080
WP_SITEURL=http://localhost:8080
# Local dev only — never enable in production.
WP_DEBUG=false

HTTP_PORT=8080
PMA_PORT=8081

# ─── WordPress secret keys ─────────────────────────────────────────────────
# REQUIRED — the stack refuses to boot if any of these are empty.
# Generate eight fresh values (one per line) with:
#   for i in {1..8}; do openssl rand -base64 48 | tr -d '\n'; echo; done
WORDPRESS_AUTH_KEY=
WORDPRESS_SECURE_AUTH_KEY=
WORDPRESS_LOGGED_IN_KEY=
WORDPRESS_NONCE_KEY=
WORDPRESS_AUTH_SALT=
WORDPRESS_SECURE_AUTH_SALT=
WORDPRESS_LOGGED_IN_SALT=
WORDPRESS_NONCE_SALT=
